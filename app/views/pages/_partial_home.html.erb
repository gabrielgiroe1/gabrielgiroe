<% desktop = local_assigns.fetch(:desktop, false) %>

<div class="<%= desktop ? 'pl-16 pr-12 py-12 relative accent-line' : 'bg-gradient-to-t from-black/70 via-black/40 to-transparent p-6 sm:p-8' %> w-full z-10">
  <div class="<%= desktop ? 'max-w-xl' : 'container mx-auto max-w-4xl' %> flex flex-col">

   

    <!-- Name -->
    <h1 class="text-4xl <%= desktop ? 'lg:text-5xl xl:text-6xl animate-fade-in-up animation-delay-200' : 'sm:text-5xl' %> font-bold text-white mb-3 tracking-tight">
      Gabriel Giroe
    </h1>

    <!-- Role subtitle -->
    <p class="text-lg <%= desktop ? 'lg:text-xl animate-fade-in-up animation-delay-200' : 'sm:text-xl' %> text-slate-300 mb-4">
      Software Engineer
    </p>

    <!-- Tagline -->
    <p class="text-base <%= desktop ? 'lg:text-lg animate-fade-in-up animation-delay-400' : 'sm:text-lg' %> text-slate-400 mb-8 max-w-md leading-relaxed">
      Building delightful web experiences with Ruby on Rails. I turn ideas into clean, maintainable code.
    </p>

    <!-- Social Links -->
    <div class="flex flex-wrap items-center gap-3 mb-8 <%= desktop ? 'animate-fade-in-up animation-delay-400' : '' %>">
      <%= link_to "https://www.instagram.com/gabriel.giroe/", target: "_blank", rel: "noopener noreferrer", aria: { label: "Instagram profile" }, class: "p-2 rounded-lg bg-white/5 hover:bg-white/10 hover:scale-110 transition-all duration-200" do %>
        <i class="fa-brands fa-instagram text-white text-xl <%= desktop ? 'lg:text-2xl' : 'sm:text-2xl' %>"></i>
      <% end %>
      <%= link_to "https://x.com/gabrielgiroe", target: "_blank", rel: "noopener noreferrer", aria: { label: "X (Twitter) profile" }, class: "p-2 rounded-lg bg-white/5 hover:bg-white/10 hover:scale-110 transition-all duration-200" do %>
        <i class="fa-brands fa-x-twitter text-white text-xl <%= desktop ? 'lg:text-2xl' : 'sm:text-2xl' %>"></i>
      <% end %>
      <%= link_to "https://www.linkedin.com/in/georgel-gabriel-giroe-26379520a/", target: "_blank", rel: "noopener noreferrer", aria: { label: "LinkedIn profile" }, class: "p-2 rounded-lg bg-white/5 hover:bg-white/10 hover:scale-110 transition-all duration-200" do %>
        <i class="fa-brands fa-linkedin-in text-white text-xl <%= desktop ? 'lg:text-2xl' : 'sm:text-2xl' %>"></i>
      <% end %>
      <%= link_to "https://github.com/gabrielgiroe1", target: "_blank", rel: "noopener noreferrer", aria: { label: "GitHub profile" }, class: "p-2 rounded-lg bg-white/5 hover:bg-white/10 hover:scale-110 transition-all duration-200" do %>
        <i class="fa-brands fa-github text-white text-xl <%= desktop ? 'lg:text-2xl' : 'sm:text-2xl' %>"></i>
      <% end %>
      <%= link_to "mailto:gabriel.giroe@gmail.com", aria: { label: "Send email" }, class: "p-2 rounded-lg bg-white/5 hover:bg-white/10 hover:scale-110 transition-all duration-200" do %>
        <i class="fa-regular fa-envelope text-white text-xl <%= desktop ? 'lg:text-2xl' : 'sm:text-2xl' %>"></i>
      <% end %>
    </div>

    <!-- CTAs -->
    <%#https://www.overleaf.com/project/67ac851d9958d511d2c95f7f  this is where i can edit my cv.%>
    <%# Edit my resume/cv with canva.com to have a good design. here is the link:
    https://www.canva.com/design/DAGmO3pXo7M/WzQFfWfnc51JpQb-6pXegQ/edit?locale=en&ui=eyJBIjp7IkUiOnsiQSI6dHJ1ZX19fQ %>
    <div class="flex flex-wrap items-center gap-4 <%= desktop ? 'animate-fade-in-up animation-delay-600' : '' %>">
      <%= link_to "https://calendly.com/gabriel-giroe1/30min", target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center gap-2 bg-yellow-500 text-black px-6 py-3 rounded-lg font-semibold shadow-lg hover:bg-yellow-400 hover:shadow-yellow-500/25 hover:shadow-xl transition-all duration-200" do %>
        <span>Let's Talk</span>
        <i class="fa-solid fa-arrow-right text-sm"></i>
      <% end %>

      <%= link_to "pages/projects", data: { turbo: false }, class: "inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-white border border-white/20 hover:bg-white/10 hover:border-white/40 transition-all duration-200" do %>
        <span>Personal project</span>
      <% end %>

      <%= link_to "/Gabriel_Giroe_CV_2025_-_Software_Engineer.pdf", target: "_blank", rel: "noopener noreferrer", aria: { label: "Download CV" }, class: "inline-flex items-center gap-2 px-4 py-3 rounded-lg text-slate-400 hover:text-white transition-colors duration-200" do %>
        <i class="fa-regular fa-file-lines text-lg"></i>
        <span>Resume</span>
      <% end %>
    </div>

  </div>
</div>