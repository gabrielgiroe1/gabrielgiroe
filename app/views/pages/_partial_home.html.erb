<% desktop = local_assigns.fetch(:desktop, false) %>

<div class="<%= desktop ? 'p-12' : 'bg-black bg-opacity-20 p-4 sm:p-8' %> w-full">
  <div class="<%= desktop ? 'max-w-lg' : 'container mx-auto max-w-4xl' %> flex flex-col">
    <!-- Name and tagline -->
    <h1 class="text-4xl <%= desktop ? 'lg:text-5xl xl:text-6xl' : 'sm:text-6xl' %> font-bold text-white mb-4">Gabriel Giroe</h1>
    <p class="text-xl <%= desktop ? 'lg:text-2xl' : 'sm:text-2xl' %> text-white mb-6">
      Software developer, using Ruby on Rails to bring joy.
      <%= link_to "https://calendly.com/gabriel-giroe1/30min", target: "_blank" do %>
        <u class="text-yellow-500 hover:text-yellow-400">Let's chat!</u>
      <% end %>
    </p>

    <!-- Social Links -->
    <div class="flex flex-wrap items-center gap-4 mb-6">
      <%= link_to "https://www.instagram.com/gabriel.giroe/", target: "_blank", class: "hover:opacity-80 transition-opacity" do %>
        <i class="fa-brands fa-instagram text-white text-3xl <%= desktop ? 'lg:text-4xl' : 'sm:text-4xl' %>"></i>
      <% end %>
      <%= link_to "https://x.com/gabrielgiroe", target: "_blank", class: "hover:opacity-80 transition-opacity" do %>
        <i class="fa-brands fa-x-twitter text-white text-3xl <%= desktop ? 'lg:text-4xl' : 'sm:text-4xl' %>"></i>
      <% end %>
      <%= link_to "https://www.linkedin.com/in/georgel-gabriel-giroe-26379520a/", target: "_blank", class: "hover:opacity-80 transition-opacity" do %>
        <i class="fa-brands fa-linkedin-in text-white text-3xl <%= desktop ? 'lg:text-4xl' : 'sm:text-4xl' %>"></i>
      <% end %>
      <%= link_to "https://github.com/gabrielgiroe1", target: "_blank", class: "hover:opacity-80 transition-opacity" do %>
        <i class="fa-brands fa-github text-white text-3xl <%= desktop ? 'lg:text-4xl' : 'sm:text-4xl' %>"></i>
      <% end %>
      <%#https://www.overleaf.com/project/67ac851d9958d511d2c95f7f  this is where i can edit my cv.%>
      <%# Edit my resume/cv with canva.com to have a good design. here is the link:
      https://www.canva.com/design/DAGmO3pXo7M/WzQFfWfnc51JpQb-6pXegQ/edit?locale=en&ui=eyJBIjp7IkUiOnsiQSI6dHJ1ZX19fQ %>
      <%= link_to "/Gabriel_Giroe_CV_2025_-_Software_Engineer.pdf", target: "_blank", class: "relative inline-block hover:opacity-80 transition-opacity" do %>
        <i class="fa-regular fa-file text-white text-3xl <%= desktop ? 'lg:text-4xl' : 'sm:text-4xl' %> relative"></i>
        <span class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-white text-xs sm:text-sm pointer-events-none">CV</span>
      <% end %>
      <%= link_to "mailto:gabriel.giroe@gmail.com", target: "_blank", class: "hover:opacity-80 transition-opacity" do %>
        <i class="fa-regular fa-envelope text-white text-3xl <%= desktop ? 'lg:text-4xl' : 'sm:text-4xl' %>"></i>
      <% end %>
    </div>

    <!-- Projects Button -->
    <div class="<%= desktop ? 'mt-4' : 'mt-2' %>">
      <%= link_to "Near you app", "pages/projects", data: { turbo: false }, class: "inline-block bg-yellow-500 text-black px-6 py-3 rounded-lg font-semibold shadow-lg hover:bg-yellow-600 transition-colors" %>
    </div>
  </div>
</div>